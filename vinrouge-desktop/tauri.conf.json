{
  "productName": "VinRouge",
  "version": "0.1.0",
  "identifier": "io.vinrouge.desktop",
  "build": {
    "frontendDist": "../vinrouge-web/dist",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VinRouge",
        "width": 1280,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "externalBin": ["binaries/ollama"]
  }
}
